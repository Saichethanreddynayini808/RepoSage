# RepoSage — Environment Configuration Example
# Copy this file to .env and fill in values as needed.
# The app works without this file — these are optional overrides.

# ── Backend ──────────────────────────────────────────────────────────────────

# Port for the FastAPI backend (default: 8000)
# BACKEND_PORT=8000

# Ollama base URL — change if running Ollama on a different host/port
# OLLAMA_BASE_URL=http://localhost:11434

# Max lines read per file (default: 200)
# MAX_LINES_PER_FILE=200

# Total character cap for all file content sent to AI (default: 400000 ≈ 100k tokens)
# MAX_TOTAL_CHARS=400000

# Warn user when repo has more than this many files (default: 500)
# LARGE_REPO_THRESHOLD=500

# ── Frontend (Vite) ───────────────────────────────────────────────────────────

# Frontend dev port (default: 5173)
# VITE_PORT=5173

# ── Notes ─────────────────────────────────────────────────────────────────────
# NEVER put your Anthropic API key or GitHub token here.
# Those are entered in the UI and kept in memory only.
